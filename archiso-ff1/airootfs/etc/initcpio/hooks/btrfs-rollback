#!/usr/bin/env bash
run_hook() {
  mkdir -p /run
  LOG="/run/btrfs-rollback.log"
  local mode="" 
  for param in $(cat /proc/cmdline); do
    case "$param" in
      rollback=factory) mode="factory" ;;
    esac
  done

  # If no rollback request, just return
  if [[ -z "$mode" ]]; then
    return 0
  fi

  echo "[btrfs-rollback] Detected rollback mode: $mode" >> $LOG
  mkdir -p /run/rollback

  local root_partuuid=""
  for param in $(cat /proc/cmdline); do
    case "$param" in
      root_partuuid=*) root_partuuid="${param#root_partuuid=}" ;;
    esac
  done
  if [[ -z "$root_partuuid" ]]; then
    echo "[btrfs-rollback] ERROR: root_partuuid not provided" >> $LOG
    return 1
  fi

  root_dev="/dev/disk/by-partuuid/$root_partuuid"
  if [[ ! -b "$root_dev" ]]; then
    echo "[btrfs-rollback] ERROR: $root_dev does not exist" >> $LOG
    return 1
  fi
  echo "[btrfs-rollback] Root device identified: $root_dev" >> $LOG

  if ! mount -o subvolid=0 "$root_dev" /run/rollback; then
    echo "[btrfs-rollback] ERROR: Failed to mount subvolid=0 on $root_dev" >> $LOG
    return 1
  fi

  local source_snap="@snapshots/@factory_reset"
  local target_at="@"

  if [[ ! -d "/run/rollback/$source_snap" ]]; then
    echo "[btrfs-rollback] ERROR: source snapshot not found: /run/rollback/$source_snap" >> $LOG
    umount /run/rollback
    return 1
  fi

  # --- Boot Partition Restoration ---
  local boot_backup="/run/rollback/$source_snap/usr/share/factory-backup/boot"
  if [[ -d "$boot_backup" ]]; then
    echo "[btrfs-rollback] Restoring boot partition from factory backup..." >> $LOG
    
    # Find EFI partition (partition 1 on same disk as root)
    local actual_root
    actual_root=$(readlink -f "$root_dev")
    local efi_part=""
    
    if [[ "$actual_root" =~ ^(.+)p([0-9]+)$ ]]; then
      # NVMe style: /dev/nvme0n1p2 -> /dev/nvme0n1p1
      efi_part="${BASH_REMATCH[1]}p1"
    elif [[ "$actual_root" =~ ^(.+[^0-9])([0-9]+)$ ]]; then
      # SATA style: /dev/sda2 -> /dev/sda1
      efi_part="${BASH_REMATCH[1]}1"
    fi
    
    if [[ -n "$efi_part" ]] && [[ -b "$efi_part" ]]; then
      mkdir -p /run/efi
      if mount -t vfat "$efi_part" /run/efi; then
        echo "[btrfs-rollback] Mounted EFI partition: $efi_part" >> $LOG
        
        # Copy boot files (kernel, initramfs, microcode)
        if [[ -f "$boot_backup/vmlinuz-linux" ]]; then
          cp -f "$boot_backup/vmlinuz-linux" /run/efi/
          echo "[btrfs-rollback] Restored vmlinuz-linux" >> $LOG
        fi
        
        if [[ -f "$boot_backup/initramfs-linux.img" ]]; then
          cp -f "$boot_backup/initramfs-linux.img" /run/efi/
          echo "[btrfs-rollback] Restored initramfs-linux.img" >> $LOG
        fi
        
        if [[ -f "$boot_backup/intel-ucode.img" ]]; then
          cp -f "$boot_backup/intel-ucode.img" /run/efi/
          echo "[btrfs-rollback] Restored intel-ucode.img" >> $LOG
        fi
        
        # Copy loader configs
        if [[ -d "$boot_backup/loader" ]]; then
          mkdir -p /run/efi/loader/entries
          cp -rf "$boot_backup/loader/"* /run/efi/loader/ 2>/dev/null
          echo "[btrfs-rollback] Restored loader configs" >> $LOG
        fi
        
        # Copy EFI directory
        if [[ -d "$boot_backup/EFI" ]]; then
          mkdir -p /run/efi/EFI
          cp -rf "$boot_backup/EFI/"* /run/efi/EFI/ 2>/dev/null
          echo "[btrfs-rollback] Restored EFI directory" >> $LOG
        fi
        
        sync
        umount /run/efi
        echo "[btrfs-rollback] Boot partition restored successfully" >> $LOG
      else
        echo "[btrfs-rollback] WARNING: Failed to mount EFI partition $efi_part" >> $LOG
      fi
    else
      echo "[btrfs-rollback] WARNING: EFI partition not found (derived: $efi_part)" >> $LOG
    fi
  else
    echo "[btrfs-rollback] WARNING: No boot backup found at $boot_backup" >> $LOG
  fi

  # --- Subvolume Operations ---
  local tmp_id
  tmp_id=$(btrfs subvolume list /run/rollback | awk -v s="$source_snap" '$NF==s { print $2 }')
  if [[ -z "$tmp_id" ]]; then
    echo "[btrfs-rollback] ERROR: Cannot find ID for $source_snap" >> $LOG
    umount /run/rollback
    return 1
  fi
  if ! btrfs subvolume set-default "$tmp_id" /run/rollback; then
    echo "[btrfs-rollback] ERROR: Failed to set-default $tmp_id" >> $LOG
    umount /run/rollback
    return 1
  fi
  echo "[btrfs-rollback] Default subvol set to $source_snap (ID $tmp_id)" >> $LOG

  if btrfs subvolume list /run/rollback | awk '$NF=="@" {print $2}' | grep -q .; then
    echo "[btrfs-rollback] Deleting old @ subvolume" >> $LOG
    if ! btrfs subvolume delete "/run/rollback/@"; then
      echo "[btrfs-rollback] ERROR: Failed to delete old @" >> $LOG
      umount /run/rollback
      return 1
    fi
  fi

  echo "[btrfs-rollback] Snapshotting $source_snap → @" >> $LOG
  if ! btrfs subvolume snapshot "/run/rollback/$source_snap" "/run/rollback/@"; then
    echo "[btrfs-rollback] ERROR: Snapshot $source_snap → @ failed" >> $LOG
    umount /run/rollback
    return 1
  fi

  new_id=$(btrfs subvolume list /run/rollback | awk -v s="@" '$NF==s { print $2 }')
  if [[ -z "$new_id" ]]; then
    echo "[btrfs-rollback] ERROR: Cannot find ID for new @" >> $LOG
    umount /run/rollback
    return 1
  fi

  if ! btrfs subvolume set-default "$new_id" /run/rollback; then
    echo "[btrfs-rollback] ERROR: Failed to set-default $new_id" >> $LOG
    umount /run/rollback
    return 1
  fi
  echo "[btrfs-rollback] Default subvol set to @ (ID $new_id)" >> $LOG

  sync
  
  echo "[btrfs-rollback] Booting into new @"  >> $LOG
  umount /run/rollback
}
